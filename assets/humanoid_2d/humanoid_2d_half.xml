<mujoco model="humanoid_2d_paired">
  <compiler angle="radian" inertiafromgeom="true"/>
  <default>
    <position kp="21.10" ctrlrange="-0.57 5.7" forcerange="-150 150"/>
    <joint armature="0.045" damping="1.084" limited="true" frictionloss="0.03"/>
    <geom conaffinity="0" condim="3" contype="1" density="50" rgba="0.8 0.6 .4 1"/>
  </default>
  <option integrator="RK4" timestep="0.002"/>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane" material="MatPlane"/>
    <camera name="track_com" mode="trackcom" pos="0 -3 -0.25" xyaxes="1 0 0 0 0 1"/>

    <body name="torso" pos="0 0 1.33">
      <joint armature="0" axis="1 0 0" damping="0" limited="false" name="rootx" pos="0 0 0" stiffness="0" type="slide"/>
      <joint armature="0" axis="0 0 1" damping="0" limited="false" name="rootz" pos="0 0 0" stiffness="0" type="slide"/>
      <joint armature="0" axis="0 1 0" damping="0" limited="false" name="rooty" pos="0 0 0" stiffness="0" type="hinge"/>

      <geom density="100" friction="0.9" name="lower_torso_geom" size="0.05 0.07" pos="0 0 -0.17" type="capsule"/>

      <body name="leg" pos="0 0.05 -0.24">
        <joint axis="0 1 0" name="leg_joint" range="-2 0" pos="0 0 0" type="hinge"/>
        <geom friction="0.9" pos="0 0 -0.225" name="leg_geom" size="0.05 0.225" type="capsule"/>
        <body name="shin" pos="0 0 -0.695">
          <joint axis="0 1 0" name="shin_joint" pos="0 0 0.25" range="0.5 2.0" type="hinge"/>
          <geom friction="0.9" name="shin_geom" size="0.05 0.25" type="capsule"/>
        </body>
      </body>

      <body name="leg_left" pos="0 -0.05 -0.24">
        <joint axis="0 1 0" name="leg_left_joint" range="-2 0" pos="0 0 0" type="hinge"/>
        <geom friction="0.9" pos="0 0 -0.225" name="leg_left_geom" size="0.05 0.225" type="capsule" rgba=".7 .3 .6 1"/>
        <body name="shin_left" pos="0 0 -0.695">
          <joint axis="0 1 0" name="shin_left_joint" pos="0 0 0.25" range="0.5 2.0" type="hinge"/>
          <geom friction="0.9" name="shin_left_geom" size="0.05 0.25" type="capsule" rgba=".7 .3 .6 1"/>
        </body>
      </body>

      <body name="upper_torso" pos="0 0 0.12">
        <joint axis="0 1 0" name="waist_joint" pos="0 0 -0.17" range="0 1.0" type="hinge"/>
        <geom density="100" friction="0.9" name="upper_torso_geom" size="0.1 0.12" pos="0 0 0" type="capsule"/>

        <geom name="head" pos="0 0 0.24" size="0.08" type="sphere" rgba="1 0 0 1"/>

        <body name="arm" pos="0 0.125 0.12">
          <joint axis="0 1 0" name="arm_joint" pos="0 0 0" range="-2.35 1.0" type="hinge"/>
          <geom friction="0.9" name="uarm_geom" pos="0 0 -0.15" size="0.04 0.15" type="capsule"/>
          <body name="forearm" pos="0 0 -0.49">
            <joint axis="0 1 0" name="forearm_joint" pos="0 0 0.19" range="4.01 6.0" type="hinge"/>
            <geom friction="0.9" name="larm_geom" pos="0 0 0.0" size="0.03 0.15" type="capsule"/>
          </body>
        </body>

        <body name="arm_left" pos="0 -0.125 0.12">
          <joint axis="0 1 0" name="arm_left_joint" pos="0 0 0" range="-2.35 1.0" type="hinge"/>
          <geom friction="0.9" name="uarm_left_geom" pos="0 0 -0.15" size="0.04 0.15" type="capsule" rgba=".7 .3 .6 1"/>
          <body name="forearm_left" pos="0 0 -0.49">
            <joint axis="0 1 0" name="forearm_left_joint" pos="0 0 0.19" range="4.01 6.0" type="hinge"/>
            <geom friction="0.9" name="larm_left_geom" pos="0 0 -0.0" size="0.03 0.15" type="capsule" rgba=".7 .3 .6 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <joint joint1="leg_joint" joint2="leg_left_joint" polycoef="0 1 0 0 0"/>
    <joint joint1="shin_joint" joint2="shin_left_joint" polycoef="0 1 0 0 0"/>
    <joint joint1="arm_joint" joint2="arm_left_joint" polycoef="0 1 0 0 0"/>
    <joint joint1="forearm_joint" joint2="forearm_left_joint" polycoef="0 1 0 0 0"/>
  </equality>

  <actuator>
    <position joint="waist_joint" name="pos_waist" ctrlrange="0 1.0"/>
    <position joint="leg_joint" name="pos_leg" ctrlrange="-2 0"/>
    <position joint="shin_joint" name="pos_shin" ctrlrange="0.5 2.0"/>
    <position joint="arm_joint" name="pos_arm" ctrlrange="-2.35 1.0"/>
    <position joint="forearm_joint" name="pos_forearm" ctrlrange="4.01 6.0"/>
  </actuator>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".4 .5 .6" rgb2="0 0 0" width="100" height="100"/>
    <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
    <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
    <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>
</mujoco>
