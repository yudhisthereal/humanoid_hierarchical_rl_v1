<mujoco model="humanoid_2d">
  <compiler angle="degree" inertiafromgeom="true"/>
  <default>
    <joint armature="0.01" damping="1.0" limited="true"/> <geom conaffinity="0" condim="3" contype="1" density="1000" friction=".7 .1 .1" rgba="0.8 0.6 .4 1"/>
  </default>
  <option integrator="RK4" timestep="0.002"/>
  
  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane" material="MatPlane"/>
    
    <body name="torso" pos="0 0 1.33">
      <camera name="track" mode="trackcom" pos="0 -3 -0.25" xyaxes="1 0 0 0 0 1"/>
      <joint armature="0" axis="1 0 0" damping="0" limited="false" name="rootx" pos="0 0 -1.33" stiffness="0" type="slide"/>
      <joint armature="0" axis="0 0 1" damping="0" limited="false" name="rootz" pos="0 0 -1.33" ref="1.33" stiffness="0" type="slide"/>
      <joint armature="0" axis="0 1 0" damping="0" limited="false" name="rooty" pos="0 0 0" stiffness="0" type="hinge"/>
      
      <geom friction="0.9" name="lower_torso_geom" size="0.05 0.12" pos="0 0 -0.12" type="capsule"/>
      
      <body name="thigh" pos="0 0 -0.24">
        <joint axis="0 -1 0" name="thigh_joint" pos="0 0 0" range="-150 0" type="hinge"/>
        <geom friction="0.9" pos="0 0 -0.225" name="thigh_geom" size="0.05 0.225" type="capsule"/>
        <body name="leg" pos="0 0 -0.7">
          <joint axis="0 -1 0" name="leg_joint" pos="0 0 0.25" range="-150 0" type="hinge"/>
          <geom friction="0.9" name="leg_geom" size="0.04 0.25" type="capsule"/>
          <body name="foot" pos="0.2 0 -0.35">
            <joint axis="0 -1 0" name="foot_joint" pos="-0.2 0 0.1" range="-45 45" type="hinge"/>
            <geom friction="0.9" pos="-0.1 0 0.1" quat="0.70710678 0 -0.70710678 0" name="foot_geom" size="0.06 0.1" type="capsule"/>
          </body>
        </body>
      </body>

      <body name="thigh_left" pos="0 0 -0.24">
        <joint axis="0 -1 0" name="thigh_left_joint" pos="0 0 0" range="-150 0" type="hinge"/>
        <geom friction="0.9" name="thigh_left_geom" rgba=".7 .3 .6 1" size="0.05 0.225" pos="0 0 -0.225" type="capsule"/>
        <body name="leg_left" pos="0 0 -0.7">
          <joint axis="0 -1 0" name="leg_left_joint" pos="0 0 0.25" range="-150 0" type="hinge"/>
          <geom friction="0.9" name="leg_left_geom" rgba=".7 .3 .6 1" size="0.04 0.25" type="capsule"/>
          <body name="foot_left" pos="0.2 0 -0.35">
            <joint axis="0 -1 0" name="foot_left_joint" pos="-0.2 0 0.1" range="-45 45" type="hinge"/>
            <geom friction="1.9" name="foot_left_geom" rgba=".7 .3 .6 1" size="0.06 0.1" pos="-0.1 0 0.1" type="capsule" quat="0.70710678 0 -0.70710678 0"/>
          </body>
        </body>
      </body>

      <body name="upper_torso" pos="0 0 0">
        <joint axis="0 -1 0" name="waist_joint" pos="0 0 0" range="-90 45" type="hinge"/>
        <geom friction="0.9" name="upper_torso_geom" size="0.05 0.12" pos="0 0 0.12" type="capsule"/>
        
        <geom name="head" pos="0 0 0.32" size="0.08" type="sphere"/>

        <body name="upper_arm" pos="0 0 0.2">
          <joint axis="0 -1 0" name="arm_joint" pos="0 0 0" range="-150 150" type="hinge"/>
          <geom friction="0.9" name="uarm_geom" pos="0 0 -0.15" size="0.04 0.15" type="capsule"/>
          <body name="lower_arm" pos="0 0 -0.3">
            <joint axis="0 -1 0" name="forearm_joint" pos="0 0 0" range="-150 0" type="hinge"/>
            <geom friction="0.9" name="larm_geom" pos="0 0 -0.15" size="0.03 0.15" type="capsule"/>
          </body>
        </body>

        <body name="upper_arm_left" pos="0 0 0.2">
          <joint axis="0 -1 0" name="arm_left_joint" pos="0 0 0" range="-150 150" type="hinge"/>
          <geom friction="0.9" name="uarm_left_geom" pos="0 0 -0.15" rgba=".7 .3 .6 1" size="0.04 0.15" type="capsule"/>
          <body name="lower_arm_left" pos="0 0 -0.3">
            <joint axis="0 -1 0" name="forearm_left_joint" pos="0 0 0" range="-150 0" type="hinge"/>
            <geom friction="0.9" name="larm_left_geom" pos="0 0 -0.15" rgba=".7 .3 .6 1" size="0.03 0.15" type="capsule"/>
          </body>
        </body>
      </body>
      
    </body>
  </worldbody>

  <actuator>
    <position ctrllimited="true" ctrlrange="-90 45"  kp="150" joint="waist_joint" name="pos_waist"/>
    
    <position ctrllimited="true" ctrlrange="-150 0"  kp="100" joint="thigh_joint" name="pos_thigh"/>
    <position ctrllimited="true" ctrlrange="-150 0"  kp="100" joint="leg_joint" name="pos_leg"/>
    <position ctrllimited="true" ctrlrange="-45 45"  kp="50"  joint="foot_joint" name="pos_foot"/>
    
    <position ctrllimited="true" ctrlrange="-150 0"  kp="100" joint="thigh_left_joint" name="pos_thigh_left"/>
    <position ctrllimited="true" ctrlrange="-150 0"  kp="100" joint="leg_left_joint" name="pos_leg_left"/>
    <position ctrllimited="true" ctrlrange="-45 45"  kp="50"  joint="foot_left_joint" name="pos_foot_left"/>
    
    <position ctrllimited="true" ctrlrange="-150 150" kp="50" joint="arm_joint" name="pos_arm"/>
    <position ctrllimited="true" ctrlrange="-150 0"   kp="50" joint="forearm_joint" name="pos_forearm"/>
    
    <position ctrllimited="true" ctrlrange="-150 150" kp="50" joint="arm_left_joint" name="pos_arm_left"/>
    <position ctrllimited="true" ctrlrange="-150 0"   kp="50" joint="forearm_left_joint" name="pos_forearm_left"/>
  </actuator>
  
  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".4 .5 .6" rgb2="0 0 0" width="100" height="100"/>
    <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
    <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
    <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>
</mujoco>